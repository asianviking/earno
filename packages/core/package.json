{
  "name": "@earno/core",
  "version": "0.1.1",
  "description": "Shared core types + request transport for earno",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asianviking/earno.git"
  },
  "homepage": "https://github.com/asianviking/earno#readme",
  "bugs": {
    "url": "https://github.com/asianviking/earno/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./earnoRequest": {
      "types": "./dist/earnoRequest.d.ts",
      "import": "./dist/earnoRequest.js",
      "default": "./dist/earnoRequest.js"
    },
    "./chains": {
      "types": "./dist/chains.d.ts",
      "import": "./dist/chains.js",
      "default": "./dist/chains.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
