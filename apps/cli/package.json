{
  "name": "earno",
  "version": "0.1.0",
  "description": "Berachain yield CLI — earn from your terminal",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asianviking/earno.git"
  },
  "homepage": "https://github.com/asianviking/earno#readme",
